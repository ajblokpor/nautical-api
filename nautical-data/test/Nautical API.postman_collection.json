    {
      "name": "Single Berth",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Updated the test script to fix the TypeError\r",
              "pm.test(\"Test status matches 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "const schema = {\r",
              "    \"type\": \"object\",\r",
              "    \"properties\": {\r",
              "        \"gln\": { \"type\": \"string\" },\r",
              "        \"name\": { \"type\": \"string\" },\r",
              "        \"berthType\": { \"type\": \"string\" },\r",
              "        \"unloCode\": { \"type\": \"string\" },\r",
              "        \"geoCoordinates\": {\r",
              "            \"type\": \"array\",\r",
              "            \"items\": [\r",
              "                {\r",
              "                    \"type\": \"object\",\r",
              "                    \"properties\": {\r",
              "                        \"latitude\": { \"type\": \"number\" },\r",
              "                        \"longitude\": { \"type\": \"number\" }\r",
              "                    },\r",
              "                    \"required\": [\"latitude\", \"longitude\"],\r",
              "                    \"additionalProperties\": false\r",
              "                }\r",
              "            ]\r",
              "        },\r",
              "        \"positions\": {\r",
              "            \"type\": \"array\",\r",
              "            \"items\": [\r",
              "                {\r",
              "                    \"type\": \"object\",\r",
              "                    \"properties\": {\r",
              "                        \"glnWithExt\": {\r",
              "                            \"type\": \"string\"\r",
              "                        },\r",
              "                        \"name\": {\r",
              "                            \"type\": \"string\"\r",
              "                        },\r",
              "                        \"type\": {\r",
              "                            \"type\": \"string\"\r",
              "                        },\r",
              "                    },\r",
              "                    \"required\": [\r",
              "                        \"glnWithExt\",\r",
              "                        \"name\",\r",
              "                        \"type\"\r",
              "                    ]\r",
              "                }\r",
              "            ]\r",
              "        },\r",
              "        \"error\": { \"type\": \"string\" }\r",
              "    },\r",
              "    \"required\": [\"gln\", \"name\", \"berthType\", \"geoCoordinates\"],\r",
              "    \"additionalProperties\": false\r",
              "};\r",
              "\r",
              "pm.test('Test body schema matches swagger definition', function () {\r",
              "    pm.response.to.have.jsonSchema(schema);\r",
              "});\r",
              "\r",
              "pm.test(\"Test terminal gln returned matches requested gln\", function () {\r",
              "    pm.expect(jsonData.gln).to.eql(pm.collectionVariables.get('berthGln'));\r",
              "});\r",
              "\r",
              "pm.test(\"Test GLN is a number\", function () {\r",
              "    const gln = jsonData.gln;\r",
              "    pm.expect(gln).to.match(/^[1-9][0-9]+$/);\r",
              "});\r",
              "\r",
              "pm.test(\"Test name is filled\", function () {\r",
              "    const name = jsonData.name;\r",
              "    pm.expect(name).to.not.be.null;\r",
              "    pm.expect(name).to.not.be.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"UNLO Code is filled\", function () {\r",
              "    const unloCode = jsonData.unloCode;\r",
              "    pm.expect(unloCode).to.not.be.null;\r",
              "    pm.expect(unloCode).to.not.be.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"coordinate is filled\", function () {\r",
              "    const coordinate = jsonData.geoCoordinates[0];\r",
              "    pm.expect(coordinate.latitude).to.be.greaterThan(0);\r",
              "    pm.expect(coordinate.longitude).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "pm.test(\"check positions if available\", function () {\r",
              "    const pos = jsonData.positions;\r",
              "\r",
              "    if(pos.length > 0) {\r",
              "        const firstPos = pos[0];\r",
              "        pm.expect(firstPos.glnWithExt).to.not.be.null;\r",
              "        pm.expect(firstPos.glnWithExt).to.not.be.empty;\r",
              "        pm.expect(firstPos.name).to.not.be.null;\r",
              "        pm.expect(firstPos.type).to.not.be.null;\r",
              "        pm.expect(firstPos.type).to.not.be.empty;\r",
              "    }\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
